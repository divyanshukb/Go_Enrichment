library(clusterProfiler)
library(org.Hs.eg.db)
library(enrichplot)
genes <- read.table("gene_list.txt", stringsAsFactors = FALSE)
gene_symbols <- genes$V1
gene_df <- bitr(gene_symbols,
                fromType = "SYMBOL",
                toType = "ENTREZID",
                OrgDb = org.Hs.eg.db)
q ()
genes <- read.table("final_gene_list.txt", stringsAsFactors = FALSE)
gene_symbols <- genes$V1
gene_df <- bitr(gene_symbols,
                fromType = "SYMBOL",
                toType = "ENTREZID",
                OrgDb = org.Hs.eg.db)
library(clusterProfiler)
library(org.Hs.eg.db)
gene_df <- bitr(gene_symbols,
                fromType = "SYMBOL",
                toType = "ENTREZID",
                OrgDb = org.Hs.eg.db)
ego <- enrichGO(gene = gene_df$ENTREZID,
                OrgDb = org.Hs.eg.db,
                ont = "BP",
                pvalueCutoff = 0.05,
                readable = TRUE)

barplot(ego)
dotplot(ego, showCategory=10)
write.csv(as.data.frame(ego), "go_results.csv")
write.csv(as.data.frame(ego), "go_results.csv")
q()
